<Window x:Class="InternalBaseWpf.Windows.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Ввод" Height="200" Width="400"
        WindowStartupLocation="CenterScreen"
        Icon="/Images/key.ico"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtPrompt" Grid.Row="0" Text="Введите значение:" Margin="0,0,0,10" />
        <TextBox x:Name="txtValue" Grid.Row="1" materialDesign:HintAssist.Hint="Значение" VerticalAlignment="Top" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="ОК" Style="{StaticResource MaterialDesignRaisedButton}" Width="80" Click="BtnOk_Click" Margin="0,0,10,0" Foreground="#fff"/>
            <Button Content="Отмена" Style="{StaticResource MaterialDesignFlatButton}" Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
