<Window x:Class="InternalBaseWpf.Windows.TouchEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Правка" Height="720" Width="700"
        WindowStartupLocation="CenterScreen"
        Icon="/Images/pencil.ico"
        ResizeMode="CanResize" Cursor="">

    <Grid Background="{StaticResource MainBackground}">
        <Border Background="White" CornerRadius="4" Margin="20" Padding="25">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ПРАВКА" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,0,20" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Grid.Column="0"
                                 x:Name="txtName"
                                 materialDesign:HintAssist.Hint="Название касания"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,10,15" />

                        <TextBox Grid.Row="1" Grid.Column="0"
                                 x:Name="txtDescription"
                                 materialDesign:HintAssist.Hint="Описание"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="80"
                                 Margin="0,0,10,15" />

                        <TextBox Grid.Row="2" Grid.Column="0"
                                 x:Name="txtMediaLink"
                                 materialDesign:HintAssist.Hint="Ссылка на СМИ"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,10,15" />

                        <TextBox Grid.Row="3" Grid.Column="0"
                                 x:Name="txtSocialLink"
                                 materialDesign:HintAssist.Hint="Ссылка на соц. сети"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,10,15" />

                        <TextBox Grid.Row="4" Grid.Column="0"
                                 x:Name="txtCoverage"
                                 materialDesign:HintAssist.Hint="Охват"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,10,15" />

                        <DatePicker Grid.Row="5" Grid.Column="0"
                                    x:Name="dpStartDate"
                                    materialDesign:HintAssist.Hint="Дата начала"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                    Margin="0,0,10,15" />

                        <DatePicker Grid.Row="6" Grid.Column="0"
                                    x:Name="dpEndDate"
                                    materialDesign:HintAssist.Hint="Дата завершения"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                    Margin="0,0,10,15" />

                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  x:Name="cmbCell"
                                  materialDesign:HintAssist.Hint="Ячейка"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Margin="10,0,0,15" />

                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  x:Name="cmbType"
                                  materialDesign:HintAssist.Hint="Тип касания"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Margin="10,0,0,15" />

                        <CheckBox Grid.Row="2" Grid.Column="1" x:Name="chkIsActive" Content="Касание активно" IsChecked="True" Margin="10,5,0,10" Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}"/>
                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="chkShopPlaced" Content="Помещение ШОП" Margin="10,5,0,10" Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}"/>
                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="chkRikPlaced" Content="Помещение РИК" Margin="10,5,0,10" Style="{StaticResource MaterialDesignFilterChipPrimaryCheckBox}"/>
                    </Grid>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="ОТМЕНА" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource ErrorBrush}" Click="BtnCancel_Click" Margin="0,0,15,0" />
                    <Button Content="СОХРАНИТЬ" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource PrimaryBlue}" Foreground="White" Width="150" Click="BtnSave_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
